{
    "extends": "../tsconfig-global.json",
    "compilerOptions": {
        "target": "es2015",
        "allowJs": false,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "module": "esnext",
        "resolveJsonModule": true,
        "noEmit": true,
        "noEmitOnError": false,
        "moduleResolution": "node",
        "noImplicitAny": false,
        "sourceMap": false,
        "lib": ["dom", "dom.iterable", "esnext"],
        "isolatedModules": true,
        "skipLibCheck": true,
        "baseUrl": "src",
        "composite": false,
        "noFallthroughCasesInSwitch": true,
        "noUnusedLocals": false,
        "jsx": "react-jsx"
    },
    "include": ["src"],
    "exclude": [
        "**/node_modules/**/*",
        // Test files are excluded from tsc because @types/jest is not installed in this package.
        // They are still type-checked by the jest runner (craco test). Add @types/jest to restore tsc coverage.
        "**/*.test.ts",
        "**/*.test.tsx"
    ]
}
